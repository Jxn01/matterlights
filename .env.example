# Home Assistant connection
HA_URL=http://homeassistant.local:8123
HA_TOKEN=replace-with-your-long-lived-access-token

# Lights to control in order
HA_LIGHT_ENTITIES=light.example_primary_left,light.example_primary_right,light.example_secondary_left,light.example_secondary_right
LIGHT_ZONE_LAYOUT=top-center,bottom-left,bottom-right,bottom-center
LIGHT_ZONE_FILE=.matterlights-zones.json
PREVIEW_OVERRIDE_FILE=.matterlights-preview.json
CONTROL_STATE_FILE=.matterlights-control.json

# Playback
# Autonomous (screen sync) vs custom (static color / pattern) is toggled live
# from the dashboard and stored in CONTROL_STATE_FILE; no env var is needed.
# Turn the lights off when the monitor goes to sleep (set false to keep custom
# colors on while the screen is asleep).
RESPECT_DISPLAY_SLEEP=true

# Sync mode
COLOR_SYNC_MODE=shared-variant
PRIMARY_LIGHT_ZONE_NAMES=top-center,bottom-left
SCREEN_CAPTURE_TARGET=primary

# Local tools
ZONE_UI_PORT=8765
DASHBOARD_PORT=8770

# Home Assistant and retry behavior
REQUEST_TIMEOUT_SECONDS=3.0
AVAILABILITY_REFRESH_SECONDS=5.0
ERROR_RETRY_SECONDS=5.0

# Update cadence and dispatch
SYNC_INTERVAL_SECONDS=0.2
INTER_LIGHT_DELAY_SECONDS=0.4
MAX_PARALLEL_LIGHT_UPDATES=6
TRANSITION_SECONDS=0.0

# Custom pattern fades use Home Assistant's transition parameter. Many Matter
# bulbs lock up on transition commands, so pattern fades are capped here and are
# OFF by default (patterns snap between colors). Raise this only if your bulbs are
# known to handle fades, e.g. MAX_PATTERN_TRANSITION_SECONDS=2.
MAX_PATTERN_TRANSITION_SECONDS=0.0

# Color tuning
COLOR_CHANGE_THRESHOLD=12
BRIGHTNESS_FLOOR=255
DARK_THRESHOLD=12
DARK_ACTIVE_RATIO_THRESHOLD=0.05
COLOR_BOOST=1.55
SAMPLE_STRIDE=121

# Optional log file override
LOG_PATH=
